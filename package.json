{
  "name": "diamond-erc3643",
  "private": true,
  "description": "ERC-3643 Security Token with Diamond Proxy and ERC-1155 for RWA",
  "version": "0.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "contracts:build": "pnpm --filter @diamond-erc3643/contracts build",
    "contracts:clean": "pnpm --filter @diamond-erc3643/contracts clean",
    "contracts:fmt": "pnpm --filter @diamond-erc3643/contracts fmt",
    "contracts:fmt:check": "pnpm --filter @diamond-erc3643/contracts fmt:check",
    "contracts:lint": "pnpm --filter @diamond-erc3643/contracts lint",
    "contracts:lint:fix": "pnpm --filter @diamond-erc3643/contracts lint:fix",
    "contracts:test": "pnpm --filter @diamond-erc3643/contracts test",
    "contracts:test:vvv": "pnpm --filter @diamond-erc3643/contracts test:vvv",
    "contracts:test:unit": "pnpm --filter @diamond-erc3643/contracts test:unit",
    "contracts:test:fuzz": "pnpm --filter @diamond-erc3643/contracts test:fuzz",
    "contracts:test:invariant": "pnpm --filter @diamond-erc3643/contracts test:invariant",
    "contracts:test:fork": "pnpm --filter @diamond-erc3643/contracts test:fork",
    "contracts:coverage": "pnpm --filter @diamond-erc3643/contracts coverage",
    "contracts:slither": "pnpm --filter @diamond-erc3643/contracts slither",
    "contracts:deploy:local": "pnpm --filter @diamond-erc3643/contracts deploy:local",
    "contracts:deploy:dry": "pnpm --filter @diamond-erc3643/contracts deploy:dry",
    "dev": "bash scripts/dev.sh",
    "dev:app": "pnpm --filter @diamond-erc3643/app dev",
    "dev:indexer": "cd packages/indexer && make run",
    "visual": "tsx packages/tools/forge-visual/src/cli.ts report -p packages/contracts -o reports --open",
    "visual:report": "tsx packages/tools/forge-visual/src/cli.ts report -p packages/contracts -o reports",
    "visual:report:open": "tsx packages/tools/forge-visual/src/cli.ts report -p packages/contracts -o reports --open",
    "visual:report:fast": "tsx packages/tools/forge-visual/src/cli.ts report -p packages/contracts -o reports --skip-coverage --skip-trace --open",
    "visual:test": "tsx packages/tools/forge-visual/src/cli.ts test -p packages/contracts -o reports",
    "visual:gas": "tsx packages/tools/forge-visual/src/cli.ts gas -p packages/contracts -o reports",
    "visual:coverage": "tsx packages/tools/forge-visual/src/cli.ts coverage -p packages/contracts -o reports",
    "visual:summary": "tsx packages/tools/forge-visual/src/cli.ts summary -p packages/contracts -o reports",
    "visual:trace": "tsx packages/tools/forge-visual/src/cli.ts trace -p packages/contracts -o reports",
    "visual:trace:open": "tsx packages/tools/forge-visual/src/cli.ts trace -p packages/contracts -o reports --open",
    "visual:test:open": "tsx packages/tools/forge-visual/src/cli.ts test -p packages/contracts -o reports --open",
    "visual:summary:open": "tsx packages/tools/forge-visual/src/cli.ts summary -p packages/contracts -o reports --open"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "tsx": "^4.21.0",
    "turbo": "^2.5.4"
  }
}
