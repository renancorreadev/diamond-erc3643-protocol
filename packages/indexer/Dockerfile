# ── Stage 1: Build ──
FROM ubuntu:24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    librocksdb-dev \
    build-essential \
    ca-certificates \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install Go 1.24
RUN wget -qO- https://go.dev/dl/go1.24.5.linux-amd64.tar.gz | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:${PATH}"

WORKDIR /src
COPY go.mod go.sum ./
ENV CGO_ENABLED=1
RUN go mod download

COPY . .
RUN go build -ldflags="-s -w" -o /indexer ./cmd/indexer/

# ── Stage 2: Runtime (same base = same libs) ──
FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    librocksdb-dev \
    ca-certificates \
    wget \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -r -s /bin/false indexer
WORKDIR /app
COPY --from=builder /indexer /app/indexer
RUN mkdir -p /app/data && chown indexer:indexer /app/data
VOLUME ["/app/data"]
USER indexer

ENV HTTP_LISTEN=:8080
ENV DATA_DIR=/app/data
EXPOSE 8080

HEALTHCHECK --interval=15s --timeout=3s --start-period=10s \
  CMD wget -qO- http://localhost:8080/health || exit 1

ENTRYPOINT ["/app/indexer"]
